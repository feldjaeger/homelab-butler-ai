# Butler Environment Variables
# Copy to .env and customize for your homelab

# API Authentication
BUTLER_TOKEN=your-secret-token-here

# Proxmox Configuration
PROXMOX_URL=https://proxmox-ip:8006
PROXMOX_USER=root@pam
# PROXMOX_PASSWORD is stored in Vaultwarden as 'proxmox-token'

# Automation Host (for VM lifecycle)
AUTOMATION_HOST=user@automation-ip

# ISO Builder
ISO_BUILDER_PATH=/opt/iso-builder/build-iso.sh

# VM Defaults
VM_DEFAULT_PASSWORD=changeme
VM_DEFAULT_USER=YOUR_USERNAME

# TTS Configuration
SPEAKER_URL=http://pi-ip:10800
CHATTERBOX_URL=http://gpu-host:8004/tts
DEFAULT_VOICE=deep_thought.mp3

# Directories (for Docker bind mounts)
API_KEY_DIR=/data/api
VAULT_CACHE_DIR=/data/vault-cache
